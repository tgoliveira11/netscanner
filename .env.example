# Gateway
GATEWAY_PORT=4000
GATEWAY_HOST=0.0.0.0
WEB_ORIGIN=http://localhost:3000

# Persistence: "prisma" (default) or "memory" (zero-setup, non-persistent)
PERSISTENCE=prisma
DATABASE_URL="file:./prisma/netscanner.db"

# Scan tuning
SCAN_CONCURRENCY=64
DISCOVERY_TIMEOUT_MS=1000
DISABLE_NMAP=false

# Web → API base (used by the browser for WebSocket + REST proxy)
NEXT_PUBLIC_API_URL=http://localhost:4000

# pfSense integration (optional) — reads DHCP leases via the REST API package.
# Leave unset to disable. Create an API key in pfSense: System → REST API → Keys.
# PFSENSE_URL=https://192.168.51.1
# PFSENSE_API_KEY=your-api-key
# PFSENSE_LEASES_PATH=/api/v2/status/dhcp_server/leases
# PFSENSE_INSECURE_TLS=true

# Fingerbank (optional) — exact device model/OS from the DHCP fingerprint.
# Get a free API key at https://fingerbank.org. Passive DHCP sniffing (:67)
# needs the agent to run as root and only captures on the agent's own LAN.
# FINGERBANK_API_KEY=your-fingerbank-key
# DHCP_SNIFF=true

# Background worker — improves inventory without manual rescans.
# BACKGROUND_ENRICH_INTERVAL_MS=60000
# BACKGROUND_SCAN_INTERVAL_MS=900000
# BACKGROUND_SCAN_ENABLED=true

# Tier-1 passive discovery (mDNS + SSDP + optional LLDP via tcpdump).
# PASSIVE_LISTENERS_ENABLED=true
# LLDP_PASSIVE_ENABLED=true
# SNMP — multi-community, switch BRIDGE-MIB, gateway ARP table
# SNMP_COMMUNITIES=public,private
# SNMP_SWITCH_HOST=192.168.1.2
# SNMP_WIFI_PORTS=24,25,26
# ROUTER_SNMP_HOST=192.168.1.1

# Fritz!Box (optional) — home router without pfSense
# FRITZBOX_URL=http://192.168.178.1
# FRITZBOX_USER=
# FRITZBOX_PASSWORD=

# Tier-2 passive discovery (needs root for tcpdump listeners)
# PASSIVE_DNS_ENABLED=true
# PASSIVE_IGMP_ENABLED=true
# PASSIVE_DHCPV6_ENABLED=true
# LLDP_STREAM_ENABLED=true

# Multi-CIDR + adaptive scan
# SCAN_CIDRS=192.168.51.0/24,192.168.52.0/24
# ADAPTIVE_SCAN_ENABLED=true
# MASSCAN_ENABLED=false
# SNMP v3 (optional — when set, tried before v2c communities)
# SNMP_V3_USER=snmpuser
# SNMP_V3_AUTH_PASS=
# SNMP_V3_PRIV_PASS=
# SNMP_V3_SEC_LEVEL=authPriv

# UniFi / Omada — authoritative WiFi via controller API
# UNIFI_URL=https://192.168.51.1
# UNIFI_API_KEY=
# UNIFI_SITE=default
# OMADA_URL=https://192.168.51.10:8043
# OMADA_CLIENT_ID=
# OMADA_CLIENT_SECRET=
# OMADA_SITE_ID=

# Router HTTP scrape (fragile — openwrt or compal)
# ROUTER_SCRAPE_URL=http://192.168.51.1
# ROUTER_SCRAPE_KIND=openwrt
# ROUTER_SCRAPE_USER=admin
# ROUTER_SCRAPE_PASSWORD=

# MAC resolver cache + IoT protocol probes
# MAC_DNS_CACHE_ENABLED=true
# PROTOCOL_PROBE_ENABLED=true
