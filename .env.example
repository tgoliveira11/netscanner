# Gateway
GATEWAY_PORT=4000
GATEWAY_HOST=0.0.0.0
WEB_ORIGIN=http://localhost:3000

# Persistence: "prisma" (default) or "memory" (zero-setup, non-persistent)
PERSISTENCE=prisma
DATABASE_URL="file:./prisma/netscanner.db"

# Scan tuning
SCAN_CONCURRENCY=64
DISCOVERY_TIMEOUT_MS=1000
DISABLE_NMAP=false

# Web → API base (used by the browser for WebSocket + REST proxy)
NEXT_PUBLIC_API_URL=http://localhost:4000

# pfSense integration (optional) — DHCP leases, ARP, gateways, and interfaces via REST API package.
# Leave unset to disable. Create an API key in pfSense: System → REST API → Keys.
# PFSENSE_URL=https://192.168.1.1
# PFSENSE_API_KEY=your-api-key
# PFSENSE_LEASES_PATH=/api/v2/status/dhcp_server/leases
# PFSENSE_INSECURE_TLS=true
# PFSENSE_TRAFFIC_ENABLED=true
# PFSENSE_SSH_USER=admin
# PFSENSE_SSH_PORT=22
# PFSENSE_SSH_PASSWORD=

# Fingerbank (optional) — exact device model/OS from the DHCP fingerprint.
# Get a free API key at https://fingerbank.org. Active DHCP sniffing (:67)
# needs the agent to run as root. Local sniff only sees VLANs on this host's
# L2 interfaces; other VLANs need remote capture on the OpenWrt switch (br-lan).
# FINGERBANK_API_KEY=your-fingerbank-key
# DHCP_SNIFF=true
# Comma-separated ifaces for tcpdump fallback (empty = auto; "any" when multi-iface)
# DHCP_SNIFF_IFACES=
# Optional SSH password for remote sniff on SNMP_SWITCH_HOST (else ROUTER_SCRAPE_* for that IP)
# DHCP_SNIFF_SSH_PASSWORD=
# Background worker — improves inventory without manual rescans.
# BACKGROUND_ENRICH_INTERVAL_MS=60000
# BACKGROUND_SCAN_INTERVAL_MS=900000
# BACKGROUND_SCAN_ENABLED=true
# BACKGROUND_PORT_RESCAN_ENABLED=true
# BACKGROUND_PORT_RESCAN_MAX_AGE_MS=604800000
# BACKGROUND_PORT_RESCAN_BATCH=3
# SPEED_TEST_ENABLED=true
# SPEED_TEST_INTERVAL_MS=3600000
# SPEED_TEST_DOWNLOAD_BYTES=10000000
# SPEED_TEST_UPLOAD_BYTES=5000000
# SPEED_TEST_URL=https://speed.cloudflare.com
# SITE_AUTO_CREATE=true
# SITE_MATCH_THRESHOLD=0.85
# SITE_AMBIGUOUS_THRESHOLD=0.6
# SITE_VPN_IGNORE_GEO=true

# ROUTER_SCRAPE_TARGETS=http://192.168.1.2|openwrt|root|pass

# Topology layout (see docs/deployment-profiles.md)
# TOPOLOGY_MODE=simple
# TOPOLOGY_VLAN_ORDER=VLAN40,VLAN10,VLAN30,VLAN20
# TOPOLOGY_WIRED_VLAN=VLAN40
# TOPOLOGY_MAC_SHARING_PREFIX=192.168.64.

# Tier-1 passive discovery (mDNS + SSDP + optional LLDP via tcpdump).
# PASSIVE_LISTENERS_ENABLED=true
# LLDP_PASSIVE_ENABLED=true
# SNMP — multi-community, switch BRIDGE-MIB, gateway ARP table
# SNMP_COMMUNITIES=public
# SNMP_SWITCH_HOST=192.168.1.2
# Bridge-port numbers (dot1dTpFdbPort) where WiFi APs uplink — clients learned there are treated as wifi
# SNMP_WIFI_PORTS=2,3,4
# ROUTER_SNMP_HOST=192.168.1.1

# Fritz!Box (optional) — home router without pfSense
# FRITZBOX_URL=http://192.168.178.1
# FRITZBOX_USER=
# FRITZBOX_PASSWORD=

# Tier-2 passive discovery (needs root for tcpdump listeners)
# PASSIVE_DNS_ENABLED=true
# PASSIVE_IGMP_ENABLED=true
# PASSIVE_DHCPV6_ENABLED=true
# LLDP_STREAM_ENABLED=true

# Multi-CIDR + adaptive scan
# SCAN_CIDRS=192.168.1.0/24,192.168.10.0/24
# ADAPTIVE_SCAN_ENABLED=true
# MASSCAN_ENABLED=false
# SNMP v3 (optional — when set, tried before v2c communities)
# SNMP_V3_USER=snmpuser
# SNMP_V3_AUTH_PASS=
# SNMP_V3_PRIV_PASS=
# SNMP_V3_SEC_LEVEL=authPriv

# UniFi / Omada — authoritative WiFi via controller API
# UNIFI_URL=https://192.168.1.1
# UNIFI_API_KEY=
# UNIFI_SITE=default
# OMADA_URL=https://192.168.1.10:8043
# OMADA_CLIENT_ID=
# OMADA_CLIENT_SECRET=
# OMADA_SITE_ID=

# Router HTTP scrape (fragile — openwrt or compal)
# Single router:
# ROUTER_SCRAPE_URL=http://192.168.1.1
# ROUTER_SCRAPE_KIND=openwrt
# ROUTER_SCRAPE_USER=admin
# ROUTER_SCRAPE_PASSWORD=
# Multiple routers (url|kind|user|password; ...):
# ROUTER_SCRAPE_TARGETS=http://192.168.1.2|openwrt|root|pass1;http://192.168.10.3|openwrt|root|pass2

# MAC resolver cache + IoT protocol probes
# MAC_DNS_CACHE_ENABLED=true
# PROTOCOL_PROBE_ENABLED=true
