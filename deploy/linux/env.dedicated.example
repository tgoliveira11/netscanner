# NetScanner dedicated Linux agent
NODE_ENV=production
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=4000
CLUSTER_ENABLED=true
CLUSTER_DEDICATED=true
CLUSTER_PREFER_LEADER=true
CLUSTER_BEACON_PORT=4010
MDNS_ENABLED=true
MDNS_HOSTNAME=netscanner
AGENT_PROFILE=full
DATABASE_URL=file:/var/lib/netscanner/netscanner.db
NETSCANNER_HOME=/var/lib/netscanner
PFSENSE_CONTROL_ENABLED=false
# PFSENSE_URL=
# PFSENSE_API_KEY=
# CLOUD_SYNC_ENABLED=false
# CLOUD_SYNC_URL=
# CLOUD_SYNC_TOKEN=
# CLOUD_PII_CONSENT=false
