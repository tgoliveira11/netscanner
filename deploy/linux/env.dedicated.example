# NetScanner dedicated Linux agent
NODE_ENV=production
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=4000
CLUSTER_ENABLED=true
CLUSTER_DEDICATED=true
CLUSTER_PREFER_LEADER=true
CLUSTER_BEACON_PORT=4010
MDNS_ENABLED=true
MDNS_HOSTNAME=netscanner
AGENT_PROFILE=full
DATABASE_URL=file:/var/lib/netscanner/netscanner.db
NETSCANNER_HOME=/var/lib/netscanner
PFSENSE_CONTROL_ENABLED=false
# PFSENSE_URL=
# PFSENSE_API_KEY=
# CLOUD_SYNC_ENABLED=false
# CLOUD_SYNC_URL=
# CLOUD_SYNC_TOKEN=
# CLOUD_PII_CONSENT=false

# Discovery enhancements (box packages: masscan snmp tshark lldpd netdiscover …)
MASSCAN_ENABLED=true
TSHARK_DEEP_ENABLED=true
LLDPD_ENABLED=true
NETDISCOVER_ENABLED=true
PASSIVE_DNS_ENABLED=true
DNS_INTEL_TOP_N=8
CVE_NVD_SYNC=false
TRAFFIC_SPIKE_BPS=50000000
# NTOPNG_URL=
# NTOPNG_TOKEN=
