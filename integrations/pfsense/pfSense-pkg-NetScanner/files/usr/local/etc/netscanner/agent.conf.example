# NetScanner pfSense subagent configuration
# Copy to /usr/local/etc/netscanner/agent.conf on the firewall.

# NetScanner agent base URL (LAN IP of the Mac/VM running the agent — NOT 127.0.0.1)
AGENT_URL=http://10.0.51.106:4000

# Must match PFSENSE_PUSH_TOKEN on the main agent (config.env)
PUSH_TOKEN=change-me-to-a-long-random-secret

# Optional identifier in push payloads
AGENT_ID=pfsense-home
