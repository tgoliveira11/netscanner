<?php
/*
 * NetScanner pfSense package — config sync, cron, install hooks.
 */

require_once("config.lib.inc");
require_once("util.inc");

define('NETSCANNER_ETC', '/usr/local/etc/netscanner');
define('NETSCANNER_CONF', NETSCANNER_ETC . '/agent.conf');
define('NETSCANNER_LOG', '/var/log/netscanner-push.log');
define('NETSCANNER_COLLECT', '/usr/local/bin/netscanner-collect');

function netscanner_config(): array {
	$cfg = config_get_path('installedpackages/netscanner/config/0', []);
	return is_array($cfg) ? $cfg : [];
}

function netscanner_enabled(): bool {
	return (netscanner_config()['enable'] ?? '') === 'on';
}

function netscanner_write_agent_conf(): void {
	global $config;
	$cfg = netscanner_config();
	$lines = [
		'# Generated by pfSense NetScanner package — do not edit manually',
		'AGENT_URL=' . ($cfg['agent_url'] ?? ''),
		'PUSH_TOKEN=' . ($cfg['push_token'] ?? ''),
		'AGENT_ID=' . ($cfg['agent_id'] ?? 'pfsense'),
	];
	if (!is_dir(NETSCANNER_ETC)) {
		mkdir(NETSCANNER_ETC, 0750, true);
	}
	file_put_contents(NETSCANNER_CONF, implode("\n", $lines) . "\n");
	chmod(NETSCANNER_CONF, 0640);
}

function netscanner_apply_cron(): void {
	global $config;
	$enabled = netscanner_enabled();
	$interval = max(1, (int)(netscanner_config()['interval'] ?? 2));
	$cmd = NETSCANNER_COLLECT;

	if (!is_array($config['cron']['item'] ?? null)) {
		$config['cron']['item'] = [];
	}

	$found = false;
	foreach ($config['cron']['item'] as $idx => $item) {
		if (strpos($item['command'] ?? '', 'netscanner-collect') !== false) {
			if (!$enabled) {
				unset($config['cron']['item'][$idx]);
			} else {
				$config['cron']['item'][$idx]['minute'] = '*/' . $interval;
				$config['cron']['item'][$idx]['hour'] = '*';
				$config['cron']['item'][$idx]['mday'] = '*';
				$config['cron']['item'][$idx]['month'] = '*';
				$config['cron']['item'][$idx]['wday'] = '*';
				$config['cron']['item'][$idx]['command'] = $cmd;
				$config['cron']['item'][$idx]['who'] = 'root';
				$found = true;
			}
		}
	}

	if ($enabled && !$found) {
		$config['cron']['item'][] = [
			'minute' => '*/' . $interval,
			'hour' => '*',
			'mday' => '*',
			'month' => '*',
			'wday' => '*',
			'command' => $cmd,
			'who' => 'root',
		];
	}

	$config['cron']['item'] = array_values($config['cron']['item']);
	write_config('NetScanner: cron updated');

	if (function_exists('system_cron_configure')) {
		system_cron_configure();
	} elseif (function_exists('configure_cron')) {
		configure_cron();
	}
}

function netscanner_sync_package(): void {
	if (platform_booting()) {
		return;
	}
	netscanner_write_agent_conf();
	netscanner_apply_cron();
}

function netscanner_install(): void {
	global $config;
	if (!is_dir(NETSCANNER_ETC)) {
		mkdir(NETSCANNER_ETC, 0750, true);
	}
	if (!file_exists(NETSCANNER_CONF) && file_exists(NETSCANNER_ETC . '/agent.conf.example')) {
		copy(NETSCANNER_ETC . '/agent.conf.example', NETSCANNER_CONF);
	}
	$defaults = [
		'enable' => '',
		'agent_url' => 'http://192.168.51.106:4000',
		'push_token' => '',
		'agent_id' => 'pfsense',
		'interval' => '2',
	];
	$existing = netscanner_config();
	if (empty($existing)) {
		config_set_path('installedpackages/netscanner/config/0', $defaults);
	} else {
		config_set_path('installedpackages/netscanner/config/0', array_merge($defaults, $existing));
	}
	write_config('NetScanner package installed');
	netscanner_sync_package();
}

function netscanner_deinstall(): void {
	global $config;
	if (is_array($config['cron']['item'] ?? null)) {
		foreach ($config['cron']['item'] as $idx => $item) {
			if (strpos($item['command'] ?? '', 'netscanner-collect') !== false) {
				unset($config['cron']['item'][$idx]);
			}
		}
		$config['cron']['item'] = array_values($config['cron']['item']);
	}
	config_del_path('installedpackages/netscanner');
	write_config('NetScanner package removed');
	if (function_exists('system_cron_configure')) {
		system_cron_configure();
	} elseif (function_exists('configure_cron')) {
		configure_cron();
	}
}

function netscanner_validate_input(array $post, array &$input_errors): void {
	if (($post['enable'] ?? '') === 'on') {
		if (empty(trim($post['agent_url'] ?? ''))) {
			$input_errors[] = gettext('Agent URL is required when NetScanner push is enabled.');
		}
		if (empty(trim($post['push_token'] ?? ''))) {
			$input_errors[] = gettext('Push token is required when NetScanner push is enabled.');
		}
	}
}

function netscanner_run_collect_now(): array {
	$out = [];
	$code = 0;
	exec(NETSCANNER_COLLECT . ' 2>&1', $out, $code);
	return ['code' => $code, 'output' => implode("\n", $out)];
}

function netscanner_tail_log(int $lines = 30): string {
	if (!file_exists(NETSCANNER_LOG)) {
		return '';
	}
	$log = file(NETSCANNER_LOG, FILE_IGNORE_NEW_LINES);
	if (!is_array($log)) {
		return '';
	}
	return implode("\n", array_slice($log, -$lines));
}

?>
