{
  "name": "netscanner",
  "version": "0.2.0",
  "license": "MIT",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "dev:api": "pnpm --filter @netscanner/gateway dev",
    "dev:web": "pnpm --filter @netscanner/web dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:push": "pnpm --filter @netscanner/inventory db:push",
    "db:generate": "pnpm --filter @netscanner/inventory db:generate"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
