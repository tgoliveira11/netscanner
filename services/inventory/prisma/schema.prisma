// Prisma schema for the device inventory. SQLite by default (portable, zero-setup);
// swap the datasource provider to postgresql and set DATABASE_URL for production.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/** A recognized network location (home, office, hotel…) with isolated inventory. */
model NetworkSiteRecord {
  id               String   @id
  name             String
  slug             String   @unique
  createdAt        DateTime @default(now())
  lastSeenAt       DateTime
  fingerprintJson  String   @default("{}")
  integrationsJson String   @default("{}")
  isDefault        Boolean  @default(false)

  devices      DeviceRecord[]
  speedTests   SpeedTestRecord[]
}

model DeviceRecord {
  id                       String   @id
  siteId                   String   @default("00000000-0000-4000-8000-000000000001")
  site                     NetworkSiteRecord @relation(fields: [siteId], references: [id], onDelete: Cascade)
  ip                       String
  mac                      String?
  vendor                   String?
  brand                    String?
  model                    String?
  hostname                 String?
  deviceType               String
  classificationConfidence Float
  connectionType           String
  latencyMs                Float?
  isOnline                 Boolean  @default(true)
  label                    String?
  notes                    String?
  routerScrapeUser         String?
  routerScrapePassword     String?
  // Complex fields serialized as JSON strings for DB portability.
  osJson                   String?
  servicesJson             String   @default("[]")
  securityFlagsJson        String   @default("[]")
  signalsJson              String   @default("{}")
  firstSeen                DateTime
  lastSeen                 DateTime

  @@unique([siteId, mac])
  @@index([siteId, ip])
  @@index([siteId, isOnline])
  @@index([deviceType])
}

/** Passive DHCP fingerprints captured by the root sniffer — survives restarts. */
model DhcpFingerprintRecord {
  siteId       String   @default("00000000-0000-4000-8000-000000000001")
  mac          String
  fingerprint  String
  vendorClass  String?
  hostname     String?
  capturedAt   DateTime

  @@id([siteId, mac])
}

/** mDNS / SSDP / LLDP signals observed passively — survives restarts. */
model PassiveSignalRecord {
  siteId      String   @default("00000000-0000-4000-8000-000000000001")
  ip          String
  mac         String?
  hostname    String?
  signalsJson String   @default("{}")
  updatedAt   DateTime @updatedAt

  @@id([siteId, ip])
}

/** Periodic WAN speed samples for reporting (download/upload/latency). */
model SpeedTestRecord {
  id            String   @id
  siteId        String   @default("00000000-0000-4000-8000-000000000001")
  site          NetworkSiteRecord? @relation(fields: [siteId], references: [id], onDelete: Cascade)
  measuredAt    DateTime @default(now())
  downloadMbps  Float?
  uploadMbps    Float?
  latencyMs     Float?
  downloadBytes Int?
  uploadBytes   Int?
  server        String   @default("cloudflare")
  trigger       String   @default("background")
  error         String?
  /** agent = default route from Mac; wan = bound to pfSense WAN iface via SSH. */
  testKind      String   @default("agent")
  wanGateway    String?
  wanInterface  String?
  /** pfSense gateway name when testKind=agent (observed egress at test time). */
  egressGateway String?
  egressRoute   String?

  @@index([siteId, measuredAt])
  @@index([testKind, measuredAt])
  @@index([wanGateway, measuredAt])
}

/** Audit trail for pfSense control actions (block, pause, DHCP, etc.). */
model PolicyAuditRecord {
  id         String   @id
  action     String
  target     String
  detailJson String   @default("{}")
  actor      String   @default("local")
  createdAt  DateTime @default(now())
  undone     Boolean  @default(false)

  @@index([createdAt])
  @@index([target])
}

/** Active internet pause with expiry (TTL enforced by gateway worker). */
model PolicyPauseRecord {
  id        String   @id
  deviceId  String?
  ip        String
  mac       String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
  @@index([ip])
}

/** Parental schedule profiles pushed to pfSense schedules. */
model ParentalScheduleRecord {
  id                String   @id
  name              String
  deviceIdsJson     String   @default("[]")
  weekdaysJson      String   @default("[]")
  startTime         String
  endTime           String
  enabled           Boolean  @default(true)
  pfsenseScheduleId String?
  createdAt         DateTime @default(now())
}

/**
 * Persisted per-device control policies (route / DNS / dest).
 * kind=route → at most one row per device (value = pfSense gateway or group name).
 * kind=dns|dest → many rows (value = domain or destination).
 */
model DevicePolicyRecord {
  id        String   @id
  siteId    String   @default("00000000-0000-4000-8000-000000000001")
  deviceId  String
  kind      String
  value     String
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@unique([deviceId, kind, value])
  @@index([deviceId, kind])
  @@index([kind])
}

/**
 * Persisted CPE / modem reverse-proxy sessions.
 * Survives agent restart; closed only via Admin "Close tunnel".
 * Password stored encrypted (SecretCipher) when available.
 */
model CpeAccessSessionRecord {
  id               String   @id
  ip               String
  port             Int      @default(80)
  tls              Boolean  @default(false)
  label            String?
  username         String
  /** AES-GCM ciphertext (enc:v1:...) or plaintext fallback. */
  passwordEnc      String
  via              String   @default("direct")
  autoLoginPending Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([ip])
}
